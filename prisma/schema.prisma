generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String             @id @default(cuid())
  phone               String             @unique
  name                String
  email               String?            @unique
  password            String
  avatar              String?
  language            String             @default("fr")
  verified            Boolean            @default(false)
  premium             Boolean            @default(false)
  premiumUntil        DateTime?
  isPremium           Boolean            @default(false)
  premiumTier         String             @default("free")
  role                String             @default("USER")
  isVendor            Boolean            @default(false)
  suspended           Boolean            @default(false)
  suspendedUntil      DateTime?
  suspendedReason     String?
  subdomain           String?            @unique
  customDomain        String?            @unique
  bannerUrl           String?
  bio                 String?
  shopTheme           String             @default("default")
  socialLinks         Json?
  fbUserId            String?
  fbAccessToken       String?
  fbPageId            String?
  fbPageName          String?
  fbPageAccessToken   String?
  videoUrl            String?
  whatsappNumber      String?
  aiReplyEnabled      Boolean            @default(true)
  galleryImages       Json?
  testimonials        Json?
  trustBadges         Json?
  fontFamily          String?            @default("inter")
  activePromotion     Json?
  aboutSection        String?
  customColors        Json?
  logoUrl             String?
  backgroundUrl       String?
  businessHours       Json?
  shopLayout          String             @default("mobile-first")
  seoTitle            String?
  seoDescription      String?
  seoKeywords         String?
  rating              Float              @default(0)
  totalRatings        Int                @default(0)
  totalSales          Int                @default(0)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  adminLogs           AdminLog[]
  buyerConversations  Conversation[]     @relation("BuyerConversations")
  sellerConversations Conversation[]     @relation("SellerConversations")
  favorites           Favorite[]
  listings            Listing[]
  messages            Message[]
  notifications       Notification[]
  payments            Payment[]
  pushSubscriptions   PushSubscription[]
  reviewsReceived     Review[]           @relation("Reviewed")
  reviewsGiven        Review[]           @relation("Reviewer")
  subscription        Subscription?
  badges              UserBadge[]

  @@index([phone])
  @@index([email])
  @@index([subdomain])
  @@map("user")
}

model Badge {
  id          String      @id @default(cuid())
  type        BadgeType   @unique
  name        String
  nameFr      String
  nameAr      String?
  description String
  icon        String
  color       String
  criteria    Json?
  createdAt   DateTime    @default(now())
  userBadges  UserBadge[]

  @@map("badge")
}

model UserBadge {
  id        String    @id @default(cuid())
  userId    String
  badgeType BadgeType
  awardedAt DateTime  @default(now())
  expiresAt DateTime?
  badge     Badge     @relation(fields: [badgeType], references: [type])
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeType])
  @@index([userId])
  @@map("userbadge")
}

model Listing {
  id               String         @id @default(cuid())
  userId           String
  title            String
  description      String
  price            Int
  category         String
  videoUrl         String
  thumbnailUrl     String
  duration         Int
  location         String
  quartier         String?
  latitude         Float?
  longitude        Float?
  status           String         @default("active")
  moderationStatus String         @default("pending")
  moderatedBy      String?
  moderatedAt      DateTime?
  rejectionReason  String?
  views            Int            @default(0)
  boosted          Boolean        @default(false)
  boostedUntil     DateTime?
  isUrgent         Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  expiresAt        DateTime
  conversations    Conversation[]
  favorites        Favorite[]
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages         Message[]
  payments         Payment[]

  @@index([category, status, createdAt])
  @@index([userId])
  @@map("listing")
}

model Conversation {
  id            String    @id @default(cuid())
  listingId     String?
  buyerId       String
  sellerId      String
  lastMessage   String?
  lastMessageAt DateTime?
  unreadCount   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  buyer         User      @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  listing       Listing?  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  seller        User      @relation("SellerConversations", fields: [sellerId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
  @@map("conversation")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  listingId      String?
  senderId       String
  content        String
  type           String       @default("text")
  mediaUrl       String?
  read           Boolean      @default(false)
  audioDuration  Int?
  fileSize       Int?
  deliveredAt    DateTime?
  readAt         DateTime?
  deleted        Boolean      @default(false)
  deletedAt      DateTime?
  deletedForAll  Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  listing        Listing?     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([listingId])
  @@index([senderId])
  @@map("message")
}

model Review {
  id         String   @id @default(cuid())
  reviewerId String
  reviewedId String
  rating     Int
  comment    String?
  featured   Boolean  @default(false)
  createdAt  DateTime @default(now())
  reviewed   User     @relation("Reviewed", fields: [reviewedId], references: [id], onDelete: Cascade)
  reviewer   User     @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([reviewerId])
  @@index([reviewedId])
  @@map("review")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@map("favorite")
}

model Payment {
  id              String         @id @default(cuid())
  userId          String
  amount          Int
  currency        String         @default("XOF")
  status          String         @default("pending")
  paymentMethod   String
  paymentMethodId String?
  transactionId   String?
  proofUrl        String?
  adminNote       String?
  reference       String         @unique
  metadata        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  listingId       String?
  listing         Listing?       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  method          PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([reference])
  @@map("payment")
}

model Subscription {
  id              String    @id @default(cuid())
  userId          String    @unique
  plan            String
  status          String    @default("active")
  startDate       DateTime  @default(now())
  endDate         DateTime?
  autoRenew       Boolean   @default(true)
  paymentMethodId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("subscription")
}

model SubscriptionPlan {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  description         String?
  price               Int
  features            Json
  maxListings         Int?
  maxVideosPerListing Int?     @default(1)
  maxVideoDuration    Int?
  allowSubdomain      Boolean  @default(false)
  allowCustomDomain   Boolean  @default(false)
  allowLiveStreaming  Boolean  @default(false)
  allowStories        Boolean  @default(false)
  priority            Int      @default(0)
  active              Boolean  @default(true)
  popular             Boolean  @default(false)
  color               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([slug])
  @@index([active])
  @@map("subscriptionplan")
}

model BoostPackage {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Int
  duration    Int
  features    Json
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
  @@map("boostpackage")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  icon      String?
  url       String?
  data      Json?
  read      Boolean          @default(false)
  sent      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@map("notification")
}

model AutomationTemplate {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  trigger     String
  conditions  Json
  actions     Json
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([active])
  @@map("automationtemplate")
}

model PaymentMethod {
  id          String    @id @default(cuid())
  name        String
  code        String    @unique
  description String?
  icon        String?
  color       String    @default("from-gray-500 to-gray-600")
  active      Boolean   @default(true)
  order       Int       @default(0)
  config      Json?
  phoneNumber String?
  paymentLink String?
  instruction String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  payments    Payment[]

  @@index([active])
  @@index([code])
  @@index([order])
  @@map("paymentmethod")
}

model PaymentMessage {
  id        String   @id @default(cuid())
  message   String
  active    Boolean  @default(true)
  bgColor   String   @default("#FF6B35")
  textColor String   @default("#FFFFFF")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paymentmessage")
}

model SiteSettings {
  id                           String   @id @default(cuid())
  siteName                     String   @default("VideoBoutique")
  siteSlogan                   String?
  siteDescription              String?
  heroTitle                    String?
  heroSubtitle                 String?
  urgentSectionTitle           String?  @default("Annonces Urgentes")
  recentSectionTitle           String?  @default("Annonces Récentes")
  shopsSectionTitle            String?  @default("Boutiques Premium")
  logo                         String?
  favicon                      String?
  pwaIcon                      String?
  contactEmail                 String?
  contactPhone                 String?
  address                      String?
  socialFacebook               String?
  socialTwitter                String?
  socialInstagram              String?
  socialLinkedIn               String?
  socialYouTube                String?
  socialTikTok                 String?
  facebookAppId                String?
  facebookAppSecret            String?
  facebookLoginEnabled         Boolean  @default(false)
  maintenanceMode              Boolean  @default(false)
  maintenanceMessage           String?
  homeLayout                   String   @default("modern")
  dashboardLayout              String   @default("nebula")
  primaryColor                 String   @default("#FF6B35")
  secondaryColor               String   @default("#F7931E")
  accentColor                  String   @default("#FDC830")
  backgroundColor              String   @default("#FFF7ED")
  headerColor                  String   @default("#FFFFFF")
  footerColor                  String   @default("#FFFFFF")
  headerTextColor              String   @default("#000000")
  footerTextColor              String   @default("#000000")
  urgentBgColor                String   @default("#FFFFFF")
  shopsBgColor                 String   @default("#FFFFFF")
  recentBgColor                String   @default("#FFFFFF")
  urgentTextColor              String   @default("#000000")
  shopsTextColor               String   @default("#000000")
  recentTextColor              String   @default("#000000")
  enableAIDescriptionGenerator Boolean  @default(true)
  homepageSections             Json?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  @@map("sitesettings")
}

model EmailConfig {
  id                    String   @id @default(cuid())
  smtpHost              String
  smtpPort              Int
  smtpUser              String
  smtpPassword          String
  fromEmail             String
  fromName              String
  isActive              Boolean  @default(false)
  welcomeTemplate       String?
  verificationTemplate  String?
  resetPasswordTemplate String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("emailconfig")
}

model Category {
  id            String     @id @default(cuid())
  name          String
  nameFr        String
  nameAr        String?
  nameEn        String?
  slug          String     @unique
  icon          String?
  image         String?
  description   String?
  order         Int        @default(0)
  isActive      Boolean    @default(true)
  color         String?
  parentId      String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  parent        Category?  @relation("SubCategories", fields: [parentId], references: [id])
  subcategories Category[] @relation("SubCategories")

  @@index([slug])
  @@index([order])
  @@index([parentId])
  @@map("category")
}

model SeoSettings {
  id                 String   @id @default(cuid())
  defaultTitle       String?
  defaultDescription String?
  defaultKeywords    String?
  ogImage            String?
  ogType             String?  @default("website")
  twitterHandle      String?
  twitterCardType    String?  @default("summary_large_image")
  googleAnalyticsId  String?
  googleTagManagerId String?
  facebookPixelId    String?
  sitemapEnabled     Boolean  @default(true)
  robotsTxt          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("seosettings")
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@map("setting")
}

model SystemLog {
  id        String   @id @default(cuid())
  type      String
  category  String
  action    String
  message   String
  metadata  Json?
  userId    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([category])
  @@index([createdAt])
  @@index([userId])
  @@map("systemlog")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("pushsubscription")
}

model Ad {
  id          String   @id @default(cuid())
  title       String
  imageUrl    String
  linkUrl     String
  position    String
  isActive    Boolean  @default(true)
  clicks      Int      @default(0)
  impressions Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([position, isActive], map: "idx_ad_pos_isact")
  @@map("ad")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("contactmessage")
}

model AutomationConfig {
  id           String          @id @default(cuid())
  feature      String          @unique
  name         String
  description  String
  category     String
  enabled      Boolean         @default(false)
  config       Json?
  apiProvider  String?
  apiKey       String?
  apiEndpoint  String?
  dailyQuota   Int?
  monthlyQuota Int?
  usageCount   Int             @default(0)
  lastResetAt  DateTime        @default(now())
  costPerCall  Float?
  totalCost    Float           @default(0)
  schedule     Json?
  conditions   Json?
  priority     Int             @default(0)
  version      String          @default("1.0")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  logs         AutomationLog[]

  @@index([feature])
  @@index([enabled])
  @@index([category])
  @@map("automationconfig")
}

model AutomationLog {
  id            String           @id @default(cuid())
  configId      String
  action        String
  feature       String
  input         Json?
  output        Json?
  error         String?
  executionTime Int?
  tokensUsed    Int?
  cost          Float?
  userId        String?
  targetId      String?
  targetType    String?
  metadata      Json?
  createdAt     DateTime         @default(now())
  config        AutomationConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
  @@index([feature])
  @@index([action])
  @@index([createdAt])
  @@index([userId])
  @@map("automationlog")
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String?
  details    Json?
  createdAt  DateTime @default(now())
  admin      User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action], map: "idx_adminlog_action")
  @@map("adminlog")
}

model SystemSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("systemsettings")
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
  @@index([expiresAt])
  @@map("verificationcode")
}

enum BadgeType {
  VERIFIED
  TOP_SELLER
  FAST_RESPONDER
  PREMIUM
  NEW_SELLER
  TRUSTED
  EXPERT
}

enum NotificationType {
  MESSAGE
  SALE
  ORDER
  REVIEW
  SYSTEM
}
